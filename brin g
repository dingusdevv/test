-- ── Draggable ──
local function Draggable(window,handle)
	local MB1=e.UserInputType.MouseButton1
	local TC=e.UserInputType.Touch
	local mouseStart,dragStart
	local rendcon,endcon,begancon
	local activeEntered=0
	local function stopDrag()
		if rendcon then rendcon:Disconnect() rendcon=nil end
		if endcon then endcon:Disconnect() endcon=nil end
	end
	local function onRend()
		local off2=uis:GetMouseLocation()-mouseStart
		window.Position=dragStart+u2(0,off2.X,0,off2.Y)
	end
	local function onBegan(a)
		if (a.UserInputType==MB1 or a.UserInputType==TC) and activeEntered==0 and not uis:GetFocusedTextBox() then
			mouseStart=uis:GetMouseLocation()
			dragStart=window.Position
			stopDrag()
			rendcon=renderstepped:Connect(onRend)
			endcon=uis.InputEnded:Connect(function(b)
				if b.UserInputType==MB1 or b.UserInputType==TC then stopDrag() end
			end)
		end
	end
	handle.MouseEnter:Connect(function()
		if begancon then begancon:Disconnect() end
		begancon=uis.InputBegan:Connect(onBegan)
	end)
	handle.MouseLeave:Connect(function()
		if begancon then begancon:Disconnect() begancon=nil end
	end)
	local function watchDes(d)
		if not d:IsA("GuiObject") then return end
		local ent,add=false,false
		local c0=d.MouseEnter:Connect(function() ent=true if not add and d.Active then activeEntered=activeEntered+1 add=true end end)
		local c1=d.MouseLeave:Connect(function() ent=false if add then activeEntered=activeEntered-1 add=false end end)
		local c2=d:GetPropertyChangedSignal("Active"):Connect(function()
			if ent then
				if add and not d.Active then activeEntered=activeEntered-1 add=false
				elseif not add and d.Active then activeEntered=activeEntered+1 add=true end
			end
		end)
		local c3; c3=d.AncestryChanged:Connect(function()
			if not d:IsDescendantOf(window) then
				if ent then activeEntered=activeEntered-1 end
				c0:Disconnect() c1:Disconnect() c2:Disconnect() c3:Disconnect()
			end
		end)
	end
	window.DescendantAdded:Connect(watchDes)
	for _,d in ipairs(window:GetDescendants()) do watchDes(d) end
end
