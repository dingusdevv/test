local function findplr(txt)
	if txt=="" then return nil end
	local low=slower(txt)
	for v in pairs(others) do if v.DisplayName==txt then return v end end
	for v in pairs(others) do if v.Name==txt then return v end end
	for v in pairs(others) do if slower(v.DisplayName)==low then return v end end
	for v in pairs(others) do if slower(v.Name)==low then return v end end
	for v in pairs(others) do if slower(v.DisplayName):find(low,1,true) then return v end end
	for v in pairs(others) do if slower(v.Name):find(low,1,true) then return v end end
	return nil
end

local function setStatus(txt,col)
	statusLabel.Text=txt
	statusLabel.TextColor3=col or C.muted
end

local originalSpeed=nil
local speedConn=nil
local target=nil

local function clearSpeedBoost()
	if speedConn then speedConn:Disconnect() speedConn=nil end
	if target and originalSpeed then
		local c=target.Character
		local hum=c and gp(c,"Humanoid","Humanoid")
		if hum then hum.WalkSpeed=originalSpeed end
		originalSpeed=nil
	end
end

local function applySpeedBoost(plr)
	clearSpeedBoost()
	if not speedEnabled then return end
	local c=plr.Character
	local hum=c and gp(c,"Humanoid","Humanoid")
	if not hum then return end
	originalSpeed=hum.WalkSpeed
	hum.WalkSpeed=hum.WalkSpeed+SPEED_BOOST
	-- reapply if character reloads
	speedConn=plr.CharacterAdded:Connect(function(char)
		twait(0.5)
		local h=gp(char,"Humanoid","Humanoid")
		if h and speedEnabled then
			originalSpeed=h.WalkSpeed
			h.WalkSpeed=h.WalkSpeed+SPEED_BOOST
		end
	end)
end

local function updateCard(plr)
	if not plr then
		cardWrap.Visible=false
		return
	end
	cardWrap.Visible=true
	local dn=plr.DisplayName~="" and plr.DisplayName or plr.Name
	avatarLetter.Text=dn:sub(1,1):upper()
	dispLabel.Text=dn
	userLabel.Text="@"..plr.Name

	local char=plr.Character
	local hum=char and gp(char,"Humanoid","Humanoid")
	local team=plr.Team and plr.Team.Name or "None"
	local hp=hum and math.floor(hum.Health).."/"..math.floor(hum.MaxHealth) or "—"
	local age=tostring(plr.AccountAge).."d"
	local ping="—"
	pcall(function() ping=tostring(math.floor(plr:GetNetworkPing()*1000)).."ms" end)

	statLabels["Team"].Text=team
	statLabels["Health"].Text=hp
	statLabels["Account Age"].Text=age
	statLabels["Ping"].Text=ping

	setStatus("")
end

searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	local txt=searchBox.Text
	local prev=target
	target=findplr(txt)
	noMatch.Visible=(txt~="" and target==nil)
	updateCard(target)
	if target~=prev then
		clearSpeedBoost()
		if target then applySpeedBoost(target) end
	end
end)

