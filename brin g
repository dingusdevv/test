local off = angles(-1.5707963267948966,0,0)

local function gp(p,n,cl)
    if typeof(p)=="Instance" then
        for _,v in ipairs(p:GetChildren()) do
            if v.Name == n and v:IsA(cl) then
                return v
            end
        end
    end
    return nil
end

