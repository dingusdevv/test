local function findplr(txt)
	if txt=="" then return nil end
	local low=slower(txt)
	for v in pairs(others) do if v.DisplayName==txt then return v end end
	for v in pairs(others) do if v.Name==txt then return v end end
	for v in pairs(others) do if slower(v.DisplayName)==low then return v end end
	for v in pairs(others) do if slower(v.Name)==low then return v end end
	for v in pairs(others) do if slower(v.DisplayName):find(low,1,true) then return v end end
	for v in pairs(others) do if slower(v.Name):find(low,1,true) then return v end end
	return nil
end

