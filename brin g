local selected

local function getPlayers()
	local t = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			table.insert(t, p)
		end
	end
	return t
end

local function score(name, q)
	name = string.lower(name)
	q = string.lower(q)
	if q == "" then return 1 end
	if name == q then return 100 end
	if string.sub(name, 1, #q) == q then return 90 end
	if string.find(name, q, 1, true) then return 50 end
	return 0
end

local function clearList()
	for _, v in ipairs(List:GetChildren()) do
		if v:IsA("TextButton") then
			v:Destroy()
		end
	end
end

local function addButton(player)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1, -5, 0, 28)
	b.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	b.BorderSizePixel = 0
	b.TextColor3 = Color3.fromRGB(255, 255, 255)
	b.Text = player.DisplayName .. " (@" .. player.Name .. ")"
	b.Parent = List

	b.MouseButton1Click:Connect(function()
		selected = player
		Info.Text = "Selected: " .. player.Name
	end)
end

local function refresh()
	clearList()

	local query = Search.Text
	local players = getPlayers()

	table.sort(players, function(a, b)
		return score(a.Name, query) > score(b.Name, query)
	end)

	for _, p in ipairs(players) do
		if score(p.Name, query) > 0 or score(p.DisplayName, query) > 0 then
			addButton(p)
		end
	end
end

Search:GetPropertyChangedSignal("Text"):Connect(refresh)
Players.PlayerAdded:Connect(refresh)
Players.PlayerRemoving:Connect(refresh)

Bring.MouseButton1Click:Connect(function()
	if not selected then return end

	local char = LocalPlayer.Character
	local targetChar = selected.Character
	if not (char and targetChar) then return end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	local thrp = targetChar:FindFirstChild("HumanoidRootPart")
	if not (hrp and thrp) then return end

	thrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
end)

refresh()
