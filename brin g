local function updateCard(plr)
	if not plr then
		noPlayerLabel.Visible=true
		avatarFrame.Visible=false
		infoFrame.Visible=false
		bringBtn.TextColor3=COL_MUTED
		bringBtn.BackgroundColor3=COL_BG_LIGHT
		return
	end
	noPlayerLabel.Visible=false
	avatarFrame.Visible=true
	infoFrame.Visible=true

	local dn=plr.DisplayName or plr.Name
	avatarLabel.Text=ssub(dn,1,1):upper()
	displayNameLabel.Text="  "..dn
	usernameLabel.Text="@"..plr.Name

	local char=plr.Character
	local hrp=char and gp(char,"HumanoidRootPart","BasePart")
	local hum=char and gp(char,"Humanoid","Humanoid")
	local health=hum and math.floor(hum.Health).."/"..math.floor(hum.MaxHealth) or "N/A"
	local pos=hrp and string.format("%.0f, %.0f, %.0f",hrp.Position.X,hrp.Position.Y,hrp.Position.Z) or "unknown"
	local team=plr.Team and plr.Team.Name or "None"

	statsLabel.Text="Team: "..team.."  HP: "..health.."\nPos: "..pos

	bringBtn.TextColor3=COL_ACCENT
	bringBtn.BackgroundColor3=COL_ACCENT_DIM
	setStatus("player found",COL_ACCENT)
end

