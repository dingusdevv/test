-- ── BRING ──
local bringing=false

bringBtn.MouseButton1Click:Connect(function()
	if bringing then
		bringing=false
		bringBtn.Text="BRING"
		bringBtn.BackgroundColor3=C.accentDim
		bringBtn.TextColor3=C.accent
		setStatus("stopped")
		return
	end
	if not target then return end

	local myChar=lp.Character
	local theirChar=target.Character
	if not (myChar and theirChar) then return setStatus("no character",C.red) end
	if not (myChar:IsDescendantOf(ws) and theirChar:IsDescendantOf(ws)) then
		return setStatus("char not in workspace",C.red)
	end

	local myHRP=gp(myChar,"HumanoidRootPart","BasePart")
	local theirHRP=gp(theirChar,"HumanoidRootPart","BasePart")
	if not (myHRP and theirHRP) then return setStatus("no HumanoidRootPart",C.red) end

	bringing=true
	bringBtn.Text="STOP"
	bringBtn.BackgroundColor3=c3(58,20,20)
	bringBtn.TextColor3=C.red
	setStatus("bringing "..target.DisplayName.."…",C.accent)

	-- snap my HRP directly under theirs and stay there
	-- direction = their look vector (or their velocity direction if moving)
	task.spawn(function()
		while bringing and myChar:IsDescendantOf(ws) and theirChar:IsDescendantOf(ws) do

			-- figure out direction: velocity if they're moving, else their look direction
			local vel=theirHRP.AssemblyLinearVelocity
			local horizVel=v3(vel.X,0,vel.Z)
			local dir
			if horizVel.Magnitude>1 then
				dir=horizVel.Unit
			else
				-- standing still: use their look vector
				dir=theirHRP.CFrame.LookVector
				dir=v3(dir.X,0,dir.Z)
				if dir.Magnitude>0.01 then dir=dir.Unit else dir=v3(0,0,1) end
			end

			-- place me just under them, slightly ahead in their direction
			-- so they walk forward into me / I travel with them
			local theirPos=theirHRP.Position
			local underPos=v3(theirPos.X,theirPos.Y-2.8,theirPos.Z)

			-- face same direction as them
			local targetCF=CFrame.lookAt(underPos,underPos+dir)

			myHRP.CFrame=targetCF
			myHRP.AssemblyLinearVelocity=horizVel  -- match their horizontal velocity so I don't lag

			twait()
		end

		if bringing then
			-- loop exited because chars left workspace
			bringing=false
			bringBtn.Text="BRING"
			bringBtn.BackgroundColor3=C.accentDim
			bringBtn.TextColor3=C.accent
			setStatus("ended",C.muted)
		end
	end)
end)

-- stop bring button while still "STOP" state after loop exits above
local function resetBtn()
	if not bringing then
		bringBtn.Text="BRING"
		bringBtn.BackgroundColor3=C.accentDim
		bringBtn.TextColor3=C.accent
	end
end

