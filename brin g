-- Draggable
local function Draggable(window,obj)
	local MB1=Enum.UserInputType.MouseButton1
	local TOUCH=Enum.UserInputType.Touch
	obj=obj or window
	local activeEntered=0
	local mouseStart=nil
	local dragStart=nil
	local rendcon=nil
	local endcon=nil
	local function onEnd(a)
		a=a.UserInputType
		if a==MB1 or a==TOUCH then
			if rendcon then rendcon:Disconnect() end
			if endcon then endcon:Disconnect() end
		end
	end
	local function onRend()
		local o=uis:GetMouseLocation()-mouseStart
		window.Position=dragStart+u2(0,o.X,0,o.Y)
	end
	local function onBegan(a)
		a=a.UserInputType
		if (a==MB1 or a==TOUCH) and activeEntered==0 and not uis:GetFocusedTextBox() then
			mouseStart=uis:GetMouseLocation()
			dragStart=window.Position
			if rendcon then rendcon:Disconnect() end
			rendcon=renderstepped:Connect(onRend)
			if endcon then endcon:Disconnect() end
			endcon=uis.InputEnded:Connect(onEnd)
		end
	end
	local begancon=nil
	obj.MouseEnter:Connect(function()
		if begancon then begancon:Disconnect() end
		begancon=uis.InputBegan:Connect(onBegan)
	end)
	obj.MouseLeave:Connect(function()
		if begancon then begancon:Disconnect() end
	end)
	local function onDes(d)
		if not d:IsA("GuiObject") then return end
		local entered,added=false,false
		local c0=d.MouseEnter:Connect(function()
			entered=true
			if not added and d.Active then activeEntered=activeEntered+1 added=true end
		end)
		local c1=d.MouseLeave:Connect(function()
			entered=false
			if added then activeEntered=activeEntered-1 added=false end
		end)
		local c2=d:GetPropertyChangedSignal("Active"):Connect(function()
			if entered then
				if added and not d.Active then activeEntered=activeEntered-1 added=false
				elseif d.Active and not added then activeEntered=activeEntered+1 added=true end
			end
		end)
		local c3
		c3=d.AncestryChanged:Connect(function()
			if not d:IsDescendantOf(window) then
				if entered then activeEntered=activeEntered-1 end
				c0:Disconnect() c1:Disconnect() c2:Disconnect() c3:Disconnect()
			end
		end)
	end
	window.DescendantAdded:Connect(onDes)
	for _,d in ipairs(window:GetDescendants()) do onDes(d) end
end
