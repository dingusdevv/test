local function hrp(p)
	local c=p.Character
	if not c then return end
	return c:FindFirstChild("HumanoidRootPart")
end

local function clear()
	for _,v in ipairs(list:GetChildren()) do
		if v:IsA("Frame") then v:Destroy() end
	end
end

local function addPlayer(p)
	if p==lp then return end

	local row=i("Frame")
	row.Size=u2(1,0,0,32)
	row.BackgroundColor3=c3(0.25,0.25,0.25)
	row.BorderSizePixel=0
	row.Parent=list

	local name=i("TextLabel")
	name.Size=u2(0.65,0,1,0)
	name.BackgroundTransparency=1
	name.Text=p.DisplayName.." @"..p.Name
	name.TextColor3=c3(1,1,1)
	name.Parent=row

	local btn=i("TextButton")
	btn.Size=u2(0.3,0,0.8,0)
	btn.Position=u2(0.68,0,0.1,0)
	btn.Text="BRING"
	btn.Parent=row

	btn.MouseButton1Click:Connect(function()
		local c=lp.Character
		local c1=p.Character
		if not (c and c1) then return end

		local hrp=gp(c,"HumanoidRootPart","BasePart")
		local hrp1=gp(c1,"HumanoidRootPart","BasePart")
		if not (hrp and hrp1) then return end

		local from=hrp1.CFrame
		local fromP=from.Position
		local to=hrp.CFrame
		local toP=to.Position

		local mag=(fromP-toP).Magnitude-3
		local lv=cf(fromP,toP).LookVector
		local vel=0
		local pos=from.Position-v3_010*2
		toP=toP-v3_010*2

		local sine=osclock()
		local lastsine=sine
		local way=0
		local reachedmaxspeed=false

		while c:IsDescendantOf(ws) and c1:IsDescendantOf(ws) do
			sine=osclock()
			local deltaTime=sine-lastsine
			lastsine=sine

			if reachedmaxspeed then
				if mag-way<reachedmaxspeed then
					vel=vel-deltaTime*speeding
					if vel<0 then break end
				end
			else
				if way>mag/2 then
					vel=vel-deltaTime*speeding
					if vel<0 then break end
				else
					vel=vel+deltaTime*speeding
					if vel>maxspeed then
						reachedmaxspeed=way
						vel=maxspeed
					end
				end
			end

			way=way+vel*deltaTime

			if hrp then
				hrp.CFrame=cf(pos+lv*way,toP)*off
				hrp.Velocity=lv*(vel+1)
				hrp.RotVelocity=v3_0
			end

			twait()
		end

		if hrp then
			hrp.CFrame=to
			hrp.Velocity=v3_0
			hrp.RotVelocity=v3_0
		end
	end)
end

local function refresh()
	clear()
	for _,p in ipairs(plrs:GetPlayers()) do
		addPlayer(p)
	end
end

plrs.PlayerAdded:Connect(refresh)
plrs.PlayerRemoving:Connect(refresh)

refresh()
gui.Parent=lp:WaitForChild("PlayerGui")
