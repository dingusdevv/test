--------------------------------------------------------
-- PLAYER SEARCH FIX
-- matches ANY part of the name or display name (case-insensitive)
--------------------------------------------------------

local function matches(plr, text)
    if text == "" then return true end
    text = text:lower()
    return plr.Name:lower():find(text) or plr.DisplayName:lower():find(text)
end

--------------------------------------------------------
-- BRING FUNCTION (YOUR ORIGINAL LOGIC)
--------------------------------------------------------

local bringing = false

local function bringTarget(target)
    if bringing then return end
    bringing = true

    local lp = LocalPlayer
    local c = lp.Character
    local c1 = target.Character
    if not (c and c1) then bringing=false return end

    local hrp = gp(c,"HumanoidRootPart","BasePart")
    local hrp1 = gp(c1,"HumanoidRootPart","BasePart")
    if not (hrp and hrp1) then bringing=false return end

    local from = hrp1.CFrame
    local to = hrp.CFrame

    local fromP = from.Position
    local toP = to.Position

    local mag = (fromP-toP).Magnitude - 3
    local lv = cf(fromP,toP).LookVector

    local vel = 0
    local pos = from.Position - v3_010*2
    toP = toP - v3_010*2

    local sine = osclock()
    local lastsine = sine

    local way = 0
    local reachedmaxspeed = false

    while bringing and c:IsDescendantOf(Workspace) and c1:IsDescendantOf(Workspace) do
        sine = osclock()
        local dt = sine - lastsine
        lastsine = sine

        if reachedmaxspeed then
            if mag - way < reachedmaxspeed then
                vel = vel - dt * speeding
                if vel < 0 then break end
            end
        else
            if way > mag/2 then
                vel = vel - dt * speeding
                if vel < 0 then break end
            else
                vel = vel + dt * speeding
                if vel > maxspeed then
                    reachedmaxspeed = way
                    vel = maxspeed
                end
            end
        end

        way = way + vel*dt

        if not hrp:IsGrounded() then
            hrp.CFrame = cf(pos + lv*way, toP) * off
            hrp.Velocity = lv*(vel+1)
            hrp.RotVelocity = v3_0
        end

        twait()
    end

    hrp.CFrame = to
    hrp.Velocity = v3_0
    hrp.RotVelocity = v3_0

    bringing = false
end

--------------------------------------------------------
-- BUILD PLAYER LIST
--------------------------------------------------------

local function rebuildList()
    for _,v in ipairs(scroll:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    local y = 0
    local query = search.Text

    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and matches(plr, query) then

            local entry = Instance.new("Frame")
            entry.Size = UDim2.new(1,0,0,70)
            entry.Position = UDim2.new(0,0,0,y)
            entry.BackgroundColor3 = Color3.fromRGB(55,55,55)
            entry.BorderSizePixel = 0
            entry.Parent = scroll

            local img = Instance.new("ImageLabel")
            img.Size = UDim2.new(0,60,0,60)
            img.Position = UDim2.new(0,5,0,5)
            img.BackgroundTransparency = 1
            img.Image = Players:GetUserThumbnailAsync(plr.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
            img.Parent = entry

            local lbl = Instance.new("TextLabel")
            lbl.Position = UDim2.new(0,75,0,10)
            lbl.Size = UDim2.new(1,-150,0,50)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.new(1,1,1)
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Text = plr.DisplayName.."  ["..plr.Name.."]"
            lbl.Parent = entry

            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(0,60,0,40)
            btn.Position = UDim2.new(1,-70,0.5,-20)
            btn.BackgroundColor3 = Color3.fromRGB(150,50,50)
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Text = "Bring"
            btn.Parent = entry

            btn.MouseButton1Click:Connect(function()
                bringTarget(plr)
            end)

            y += 75
        end
    end

    scroll.CanvasSize = UDim2.new(0,0,0,y)
end

search:GetPropertyChangedSignal("Text"):Connect(rebuildList)
Players.PlayerAdded:Connect(rebuildList)
Players.PlayerRemoving:Connect(rebuildList)

rebuildList()

--------------------------------------------------------
-- optional: make the window draggable
--------------------------------------------------------

local dragging
local dragStart
local startPos

main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)
