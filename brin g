-- ── BRING ──
local bringing=false

bringBtn.MouseButton1Click:Connect(function()
	if bringing then
		bringing=false
		bringBtn.Text="bring"
		bringBtn.BackgroundColor3=C.btn
		bringBtn.TextColor3=C.btnText
		return
	end
	if not target then return end
	local c=lp.Character
	local c1=target.Character
	if not (c and c1) then return notify("no character") end
	if not (c:IsDescendantOf(ws) and c1:IsDescendantOf(ws)) then return notify("character not in workspace") end
	local hrp=gp(c,"HumanoidRootPart","BasePart")
	local hrp1=gp(c1,"HumanoidRootPart","BasePart")
	if not (hrp and hrp1) then return notify("no humanoidrootpart") end

	bringing=true
	bringBtn.Text="bringing"
	bringBtn.TextColor3=C.accent

	local from=hrp1.CFrame
	local fromP=from.Position
	local to=hrp.CFrame
	local toP=to.Position
	local mag=(fromP-toP).Magnitude-3
	local lv=cf(fromP,toP).LookVector
	local vel=0
	local pos=from.Position-v3_010*2
	toP=toP-v3_010*2

	local sine=osclock()
	local lastsine=sine
	local way=0
	local reachedmaxspeed=false

	while bringing and c:IsDescendantOf(ws) and c1:IsDescendantOf(ws) do
		sine=osclock()
		local deltaTime=sine-lastsine
		lastsine=sine
		if reachedmaxspeed then
			if mag-way<reachedmaxspeed then
				vel=vel-deltaTime*speeding
				if vel<0 then break end
			end
		else
			if way>mag/2 then
				vel=vel-deltaTime*speeding
				if vel<0 then break end
			else
				vel=vel+deltaTime*speeding
				if vel>maxspeed then
					reachedmaxspeed=way
					vel=maxspeed
				end
			end
		end
		way=way+vel*deltaTime
		if not hrp:IsGrounded() then
			hrp.CFrame=cf(pos+lv*way,toP)*off
			hrp.Velocity=lv*(vel+1)
			hrp.RotVelocity=v3_0
		end
		twait()
	end

	hrp.CFrame=to
	hrp.Velocity=v3_0
	hrp.RotVelocity=v3_0
	bringing=false
	bringBtn.Text="bring"
	bringBtn.BackgroundColor3=C.btn
	bringBtn.TextColor3=C.btnText
end)

-- ── SPEED ASSIST ──
local assisting=false

task.spawn(function()
	while true do
		twait()
		if speedEnabled and target and not bringing and not assisting then
			assisting=true
			task.spawn(function()
				while speedEnabled and target and not bringing do
					local c=lp.Character
					local c1=target and target.Character
					if not (c and c1) then twait() continue end
					if not (c:IsDescendantOf(ws) and c1:IsDescendantOf(ws)) then twait() continue end
					local hrp=gp(c,"HumanoidRootPart","BasePart")
					local hrp1=gp(c1,"HumanoidRootPart","BasePart")
					if not (hrp and hrp1) then twait() continue end

					local tv=hrp1.Velocity
					local horizV=v3(tv.X,0,tv.Z)
					local walkspeed=horizV.Magnitude

					if walkspeed<=0.5 then
						-- park cleanly under feet while stopped
						local footY=hrp1.Position.Y-hrp1.Size.Y/2
						hrp.CFrame=cf(v3(hrp1.Position.X,footY,hrp1.Position.Z))*off
						hrp.Velocity=v3_0
						hrp.RotVelocity=v3_0
						twait()
						continue
					end

					local dir=horizV.Unit
					local footY=hrp1.Position.Y-hrp1.Size.Y/2
					local vel=0
					local way=0
					local reachedmaxspeed=false
					local sine=osclock()
					local lastsine=sine

					while bringing==false and speedEnabled and target do
						sine=osclock()
						local dt=sine-lastsine
						lastsine=sine

						local tv2=hrp1.Velocity
						local hv2=v3(tv2.X,0,tv2.Z)
						if hv2.Magnitude<=0.5 then break end

						local newDir=hv2.Unit

						-- reset on turn
						if dir:Dot(newDir)<0.85 then
							vel=0
							way=0
							reachedmaxspeed=false
						end

						dir=newDir
						footY=hrp1.Position.Y-hrp1.Size.Y/2

						local basePos=v3(hrp1.Position.X,footY,hrp1.Position.Z)
						local toP=basePos+dir*50

						-- clamp: if more than 4 studs ahead in walk dir, reset
						local myHorizPos=v3(hrp.Position.X,footY,hrp.Position.Z)
						local ahead=(myHorizPos-basePos):Dot(dir)
						if ahead>75 then
							vel=0
							way=0
							reachedmaxspeed=false
						end

						if reachedmaxspeed then
							if (basePos-v3(hrp.Position.X,footY,hrp.Position.Z)).Magnitude<reachedmaxspeed then
								vel=vel-dt*speeding
								if vel<0 then break end
							end
						else
							vel=vel+dt*speeding
							if vel>maxspeed then
								reachedmaxspeed=way
								vel=maxspeed
							end
						end

						way=way+vel*dt

						local newPos=v3(basePos.X+dir.X*way,footY,basePos.Z+dir.Z*way)
						hrp.CFrame=cf(newPos,toP)*off
						hrp.Velocity=dir*(vel+1)
						hrp.RotVelocity=v3_0

						twait()
					end

					local footYFinal=hrp1.Position.Y-hrp1.Size.Y/2
					hrp.CFrame=cf(v3(hrp1.Position.X,footYFinal,hrp1.Position.Z))*off
					hrp.Velocity=v3_0
					hrp.RotVelocity=v3_0
				end
				assisting=false
			end)
		elseif (not speedEnabled or not target or bringing) and assisting then
			assisting=false
		end
	end
end)

-- ── JUMP ASSIST ──
task.spawn(function()
	local lastY=nil
	local jumpFired=false
	while true do
		twait()
		if not jumpEnabled or not target or bringing then
			lastY=nil
			jumpFired=false
			continue
		end

		local c=lp.Character
		local c1=target and target.Character
		if not (c and c1) then continue end
		if not (c:IsDescendantOf(ws) and c1:IsDescendantOf(ws)) then continue end
		local hrp=gp(c,"HumanoidRootPart","BasePart")
		local hrp1=gp(c1,"HumanoidRootPart","BasePart")
		if not (hrp and hrp1) then continue end

		local currentY=hrp1.Position.Y

		-- detect upward movement start = jump
		local jumping=hrp1.Velocity.Y>2

		if jumping and not jumpFired then
			jumpFired=true
			task.spawn(function()
				-- snap directly under their feet
				local footY=hrp1.Position.Y-hrp1.Size.Y/2
				hrp.CFrame=cf(v3(hrp1.Position.X,footY-0.5,hrp1.Position.Z))
				hrp.Velocity=v3_0
				hrp.RotVelocity=v3_0

				-- flick up
				hrp.Velocity=v3(0,jumpPower,0)
				hrp.RotVelocity=v3_0

				-- sustain upward push for 0.12s so it stays under them through lag
				local t=0
				while t<0.12 do
					local dt=twait()
					t=t+dt
					if not hrp1 or not hrp then break end
					local fp=hrp1.Position.Y-hrp1.Size.Y/2
					hrp.CFrame=cf(v3(hrp1.Position.X,fp-0.5,hrp1.Position.Z))
					hrp.Velocity=v3(0,jumpPower,0)
					hrp.RotVelocity=v3_0
				end
			end)
		end

		-- reset once they land (velocity Y near 0 or negative after a jump)
		if jumpFired and hrp1.Velocity.Y<=-1 then
			jumpFired=false
		end

		lastY=currentY
	end
end)

