-- ── BRING (original working logic) ──
local bringing=false

local function off() return angles(-1.5707963267948966,0,0) end

bringBtn.MouseButton1Click:Connect(function()
	if bringing then
		bringing=false
		bringBtn.Text="bring"
		bringBtn.BackgroundColor3=C.btn
		bringBtn.TextColor3=C.btnText
		setStatus("stopped")
		return
	end
	if not target then return end

	local myChar=lp.Character
	local theirChar=target.Character
	if not (myChar and theirChar) then return setStatus("no character",C.red) end
	if not (myChar:IsDescendantOf(ws) and theirChar:IsDescendantOf(ws)) then return setStatus("not in workspace",C.red) end

	local myHRP=gp(myChar,"HumanoidRootPart","BasePart")
	local theirHRP=gp(theirChar,"HumanoidRootPart","BasePart")
	if not (myHRP and theirHRP) then return setStatus("no HumanoidRootPart",C.red) end

	bringing=true
	bringBtn.Text="stop"
	bringBtn.BackgroundColor3=c3(255,220,220)
	bringBtn.TextColor3=C.red
	setStatus("bringing…",C.accent)

	task.spawn(function()
		-- original bring: fly their HRP toward mine smoothly
		local fromCF=theirHRP.CFrame
		local fromP=fromCF.Position
		local toCF=myHRP.CFrame
		local toP=toCF.Position
		local mag=(fromP-toP).Magnitude-3
		local lv=cf(fromP,toP).LookVector
		local vel=0
		local startPos=fromP-v3_010*2
		local destP=toP-v3_010*2

		local sine=osclock()
		local lastsine=sine
		local way=0
		local reachedMax=false

		while bringing and myChar:IsDescendantOf(ws) and theirChar:IsDescendantOf(ws) do
			sine=osclock()
			local dt=sine-lastsine
			lastsine=sine

			if reachedMax then
				if mag-way<reachedMax then
					vel=vel-dt*BRING_SPEED
					if vel<0 then break end
				end
			else
				if way>mag/2 then
					vel=vel-dt*BRING_SPEED
					if vel<0 then break end
				else
					vel=vel+dt*BRING_SPEED
					if vel>BRING_MAX then reachedMax=way vel=BRING_MAX end
				end
			end

			way=way+vel*dt
			if not theirHRP:IsGrounded() then
				theirHRP.CFrame=cf(startPos+lv*way,destP)*off()
				theirHRP.AssemblyLinearVelocity=lv*(vel+1)
				theirHRP.AssemblyAngularVelocity=v3_0
			end
			twait()
		end

		theirHRP.CFrame=toCF
		theirHRP.AssemblyLinearVelocity=v3_0
		theirHRP.AssemblyAngularVelocity=v3_0
		bringing=false
		bringBtn.Text="bring"
		bringBtn.BackgroundColor3=C.btn
		bringBtn.TextColor3=C.btnText
		setStatus("arrived",C.accent)
	end)
end)

-- ── SPEED ASSIST (treadmill) ──
-- Separate loop: reads their walk direction each frame, moves my HRP to assist
local assistRunning=false

task.spawn(function()
	while true do
		twait()
		if not speedEnabled or not target then
			assistRunning=false
			continue
		end
		if bringing then continue end  -- don't conflict with bring

		local myChar=lp.Character
		local theirChar=target.Character
		if not (myChar and theirChar) then continue end
		if not (myChar:IsDescendantOf(ws) and theirChar:IsDescendantOf(ws)) then continue end

		local myHRP=gp(myChar,"HumanoidRootPart","BasePart")
		local theirHRP=gp(theirChar,"HumanoidRootPart","BasePart")
		if not (myHRP and theirHRP) then continue end

		-- their horizontal velocity = their actual walk direction and speed
		local vel=theirHRP.AssemblyLinearVelocity
		local horizVel=v3(vel.X,0,vel.Z)
		local speed=horizVel.Magnitude

		local theirPos=theirHRP.Position

		if speed>0.5 then
			-- they are walking: place my HRP just under them, pushed slightly in walk direction
			-- so I "treadmill" them forward by being a moving platform under their feet
			local dir=horizVel.Unit
			-- position: slightly ahead of them in walk direction so they step onto me
			local assistPos=v3(theirPos.X,theirPos.Y-2.8,theirPos.Z) + dir*1.5
			local targetCF=CFrame.lookAt(assistPos,assistPos+dir)
			myHRP.CFrame=targetCF
			-- match their velocity exactly so I move with them (treadmill effect)
			myHRP.AssemblyLinearVelocity=horizVel*1.5  -- slightly faster pushes them
			myHRP.AssemblyAngularVelocity=v3_0
		else
			-- stopped: sit directly under them, no push
			local underCF=cf(theirPos.X,theirPos.Y-2.8,theirPos.Z)
			myHRP.CFrame=underCF
			myHRP.AssemblyLinearVelocity=v3_0
			myHRP.AssemblyAngularVelocity=v3_0
		end
	end
end)

