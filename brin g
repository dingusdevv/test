-- ── Draggable ──
local function Draggable(window,handle)
	local MB1=en.UserInputType.MouseButton1
	local TC=en.UserInputType.Touch
	local mStart,dStart,rendcon,endcon,bcon
	local ae=0
	local function stop() if rendcon then rendcon:Disconnect() rendcon=nil end if endcon then endcon:Disconnect() endcon=nil end end
	handle.MouseEnter:Connect(function()
		if bcon then bcon:Disconnect() end
		bcon=uis.InputBegan:Connect(function(a)
			if (a.UserInputType==MB1 or a.UserInputType==TC) and ae==0 and not uis:GetFocusedTextBox() then
				mStart=uis:GetMouseLocation() dStart=window.Position stop()
				rendcon=renderstepped:Connect(function() local o=uis:GetMouseLocation()-mStart window.Position=dStart+u2(0,o.X,0,o.Y) end)
				endcon=uis.InputEnded:Connect(function(b) if b.UserInputType==MB1 or b.UserInputType==TC then stop() end end)
			end
		end)
	end)
	handle.MouseLeave:Connect(function() if bcon then bcon:Disconnect() bcon=nil end end)
	local function wd(d)
		if not d:IsA("GuiObject") then return end
		local ent,add=false,false
		local c0=d.MouseEnter:Connect(function() ent=true if not add and d.Active then ae=ae+1 add=true end end)
		local c1=d.MouseLeave:Connect(function() ent=false if add then ae=ae-1 add=false end end)
		local c2=d:GetPropertyChangedSignal("Active"):Connect(function()
			if ent then if add and not d.Active then ae=ae-1 add=false elseif not add and d.Active then ae=ae+1 add=true end end
		end)
		local c3; c3=d.AncestryChanged:Connect(function()
			if not d:IsDescendantOf(window) then if ent then ae=ae-1 end c0:Disconnect() c1:Disconnect() c2:Disconnect() c3:Disconnect() end
		end)
	end
	window.DescendantAdded:Connect(wd)
	for _,d in ipairs(window:GetDescendants()) do wd(d) end
end
