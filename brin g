local function findplr(txt)
	if txt=="" then return nil end
	local lower=slower(txt)
	for v in pairs(others) do if v.DisplayName==txt then return v end end
	for v in pairs(others) do if v.Name==txt then return v end end
	for v in pairs(others) do if slower(v.DisplayName)==lower then return v end end
	for v in pairs(others) do if slower(v.Name)==lower then return v end end
	local l=#txt
	for v in pairs(others) do if ssub(v.DisplayName,1,l)==txt then return v end end
	for v in pairs(others) do if ssub(v.Name,1,l)==txt then return v end end
	for v in pairs(others) do if slower(ssub(v.DisplayName,1,l))==lower then return v end end
	for v in pairs(others) do if slower(ssub(v.Name,1,l))==lower then return v end end
	for v in pairs(others) do if slower(v.DisplayName):find(lower,1,true) then return v end end
	for v in pairs(others) do if slower(v.Name):find(lower,1,true) then return v end end
	return nil
end

