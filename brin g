local function gp(p,n,cl)
	if typeof(p)~="Instance" then return nil end
	for _,v in ipairs(p:GetChildren()) do
		if v.Name==n and v:IsA(cl) then return v end
	end
	return nil
end

local function rstr(l)
	l=l or mr(8,15)
	local s=""
	for _=1,l do
		s=s..(mr(1,2)==1 and sc(mr(65,90)) or sc(mr(97,122)))
	end
	return s
end

