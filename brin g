local function mk(cls,props,parent)
	local o=new(cls)
	for k,v in pairs(props) do o[k]=v end
	if parent then o.Parent=parent end
	return o
end
local function corner(p,r) local c=new("UICorner") c.CornerRadius=UDim.new(0,r or 6) c.Parent=p end
local function pad(p,t,ri,b,l)
	local u=new("UIPadding")
	u.PaddingTop=UDim.new(0,t or 0) u.PaddingRight=UDim.new(0,ri or 0)
	u.PaddingBottom=UDim.new(0,b or 0) u.PaddingLeft=UDim.new(0,l or 0)
	u.Parent=p
end
local function stroke(p,col,th)
	local s=new("UIStroke") s.Color=col or C.border s.Thickness=th or 1
	s.ApplyStrokeMode=en.ApplyStrokeMode.Border s.Parent=p
end

