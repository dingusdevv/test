local Players = game:GetService("Players")
local lp = Players.LocalPlayer

local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "LocalAdminPanel"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 260, 0, 340)
frame.Position = UDim2.new(0.5, -130, 0.5, -170)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Active = true
frame.Draggable = true
Instance.new("UICorner", frame)

local search = Instance.new("TextBox", frame)
search.Size = UDim2.new(1, -20, 0, 30)
search.Position = UDim2.new(0,10,0,10)
search.PlaceholderText = "Search player..."
search.Text = ""

local list = Instance.new("ScrollingFrame", frame)
list.Size = UDim2.new(1, -20, 1, -120)
list.Position = UDim2.new(0,10,0,50)
list.BackgroundColor3 = Color3.fromRGB(35,35,35)
list.ScrollBarThickness = 4

local layout = Instance.new("UIListLayout", list)

local selected

-- smart partial match (fixed + compact)
local function match(p, t)
	t = t:lower()
	return p.Name:lower():sub(1,#t) == t
		or p.DisplayName:lower():sub(1,#t) == t
end

local function getHRP()
	local c = lp.Character
	return c and c:FindFirstChild("HumanoidRootPart")
end

local function refresh()
	for _,v in ipairs(list:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end

	for _,p in ipairs(Players:GetPlayers()) do
		if p ~= lp then
			if search.Text == "" or match(p, search.Text) then
				local b = Instance.new("TextButton", list)
				b.Size = UDim2.new(1,0,0,30)
				b.Text = p.DisplayName .. " @" .. p.Name
				b.BackgroundColor3 = Color3.fromRGB(45,45,45)
				b.TextColor3 = Color3.new(1,1,1)

				b.MouseButton1Click:Connect(function()
					selected = p
				end)
			end
		end
	end

	task.wait()
	list.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end

search:GetPropertyChangedSignal("Text"):Connect(refresh)
Players.PlayerAdded:Connect(refresh)
Players.PlayerRemoving:Connect(refresh)

task.spawn(function()
	while true do
		refresh()
		task.wait(2)
	end
end)

-- BRING (local = teleport YOU to target)
local bring = Instance.new("TextButton", frame)
bring.Size = UDim2.new(0.5,-15,0,40)
bring.Position = UDim2.new(0,10,1,-80)
bring.Text = "BRING"

bring.MouseButton1Click:Connect(function()
	if not selected then return end
	local hrp = getHRP()
	local thrp = selected.Character and selected.Character:FindFirstChild("HumanoidRootPart")
	if hrp and thrp then
		hrp.CFrame = thrp.CFrame * CFrame.new(0,0,-3)
	end
end)

-- FLING (local = launch YOU toward target for 1 second, then return)
local fling = Instance.new("TextButton", frame)
fling.Size = UDim2.new(0.5,-15,0,40)
fling.Position = UDim2.new(0.5,5,1,-80)
fling.Text = "FLING"

fling.MouseButton1Click:Connect(function()
	if not selected then return end

	local hrp = getHRP()
	local thrp = selected.Character and selected.Character:FindFirstChild("HumanoidRootPart")
	if not (hrp and thrp) then return end

	local old = hrp.CFrame
	local start = tick()

	while tick() - start < 1 do
		local dir = (thrp.Position - hrp.Position).Unit
		hrp.AssemblyLinearVelocity = dir * 120 + Vector3.new(0,60,0)
		task.wait()
	end

	hrp.CFrame = old
	hrp.AssemblyLinearVelocity = Vector3.zero
end)
