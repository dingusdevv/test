-- Improved search: exact display → exact name → lower display → lower name → partial display → partial name
local function findplr(txt)
	if txt=="" then return nil end
	local lower=slower(txt)
	-- exact
	for v in pairs(others) do
		if v.DisplayName==txt then return v end
	end
	for v in pairs(others) do
		if v.Name==txt then return v end
	end
	-- lower exact
	for v in pairs(others) do
		if slower(v.DisplayName)==lower then return v end
	end
	for v in pairs(others) do
		if slower(v.Name)==lower then return v end
	end
	-- contains
	for v in pairs(others) do
		if slower(v.DisplayName):find(lower,1,true) then return v end
	end
	for v in pairs(others) do
		if slower(v.Name):find(lower,1,true) then return v end
	end
	return nil
end

