local function updateCard(plr)
	if not plr then
		infoBlock.Visible=false
		nameBtnLabel.Text="Playername"
		nameBtnLabel.TextColor3=C.btnText
		avatarLetter.Text="?" avatarLetter.TextColor3=C.muted
		iconFrame.Visible=true
		return
	end
	iconFrame.Visible=false
	infoBlock.Visible=true
	local dn=plr.DisplayName~="" and plr.DisplayName or plr.Name
	nameBtnLabel.Text=dn
	nameBtnLabel.TextColor3=c3(30,30,30)
	avatarLetter.Text=dn:sub(1,1):upper()
	avatarLetter.TextColor3=C.accent

	local char=plr.Character
	local hum=char and gp(char,"Humanoid","Humanoid")
	local team=plr.Team and plr.Team.Name or "None"
	local hp=hum and math.floor(hum.Health).."/"..math.floor(hum.MaxHealth) or "—"
	local age=plr.AccountAge.."d"
	local ping="—"
	pcall(function() ping=math.floor(plr:GetNetworkPing()*1000).."ms" end)

	statVals["display"].Text=dn
	statVals["username"].Text="@"..plr.Name
	statVals["team"].Text=team
	statVals["health"].Text=hp
	statVals["age"].Text=age
	statVals["ping"].Text=ping
end

