local function hrp(p)
	local c = p.Character
	if not c then return end
	return c:FindFirstChild("HumanoidRootPart")
end

local function clear()
	for _, v in ipairs(holder:GetChildren()) do
		if v:IsA("Frame") then
			v:Destroy()
		end
	end
end

local function addPlayer(p)
	if p == lp then return end

	local row = make("Frame")
	row.Size = UDim2.new(1,0,0,32)
	row.BackgroundColor3 = Color3.fromRGB(50,50,50)
	row.BorderSizePixel = 0
	row.Parent = holder

	local name = make("TextLabel")
	name.Size = UDim2.new(0.65,0,1,0)
	name.BackgroundTransparency = 1
	name.Text = p.DisplayName .. " @" .. p.Name
	name.TextColor3 = Color3.fromRGB(255,255,255)
	name.Parent = row

	local btn = make("TextButton")
	btn.Size = UDim2.new(0.3,0,0.8,0)
	btn.Position = UDim2.new(0.68,0,0.1,0)
	btn.Text = "BRING"
	btn.Parent = row

	btn.MouseButton1Click:Connect(function()
		local target = p
		local lpChar = lp.Character
		local tChar = target.Character
		if not (lpChar and tChar) then return end

		local lpH = lpChar:FindFirstChild("HumanoidRootPart")
		local tH = tChar:FindFirstChild("HumanoidRootPart")
		if not (lpH and tH) then return end

		local start = tH.Position
		local goal = lpH.Position - Vector3.new(0, 3, 0)

		local distance = (start - goal).Magnitude
		local dir = (goal - start).Unit

		local speed = 0
		local pos = start
		local t = 0

		while (pos - goal).Magnitude > 2 do
			t += rs.RenderStepped:Wait()

			local remaining = (pos - goal).Magnitude

			if remaining < distance * 0.4 then
				speed = math.max(speed - 2, 0)
			else
				speed = math.min(speed + 2, 75)
			end

			pos = pos + dir * speed * rs.RenderStepped:Wait()

			if tChar and tChar.Parent then
				tH.CFrame = cf(pos) * off
				tH.AssemblyLinearVelocity = Vector3.zero
				tH.AssemblyAngularVelocity = Vector3.zero
			end
		end

		tH.CFrame = cf(goal)
	end)
end

local function refresh()
	clear()
	for _, p in ipairs(plrs:GetPlayers()) do
		addPlayer(p)
	end
end

plrs.PlayerAdded:Connect(refresh)
plrs.PlayerRemoving:Connect(refresh)

refresh()

gui.Parent = lp:WaitForChild("PlayerGui")
